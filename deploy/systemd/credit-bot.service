[Unit]
Description=Credit Spread Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/bot_credit
ExecStart=/bin/bash -c '/usr/bin/python3 -u /home/ubuntu/bot_credit/bot_v3.py >> /home/ubuntu/bot_credit/credit.log 2>&1'
Restart=always
RestartSec=10
MemoryMax=300M

[Install]
WantedBy=multi-user.target
