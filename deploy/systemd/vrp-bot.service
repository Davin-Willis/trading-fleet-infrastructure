[Unit]
Description=Volatility Risk Premium Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/bot_vrp
ExecStart=/bin/bash -c "/usr/bin/python3 -u /home/ubuntu/bot_vrp/vrp_bot.py >> /home/ubuntu/bot_vrp/vrp.log 2>&1"
Restart=always
RestartSec=10
MemoryMax=300M

[Install]
WantedBy=multi-user.target
