# Per-bot configuration. Each bot folder gets its own .env.
# NEVER commit a real .env.

# Alpaca paper account (one per bot)
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_PAPER=true

# Discord webhook for this bot's channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Regime-aware bots only
REGIME_STATE_FILE=/home/ubuntu/shared/regime_state.json
REGIME_STALE_HOURS=100
